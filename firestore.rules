rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedAdmin() {
      return request.auth != null && request.auth.token.email == 'zhannabie@gmail.com';
    }

    // Passwordless guest identity (see js/guest.js): a guest doc's `firebaseUid`
    // is the anonymous-auth uid currently bound to that name+nickname pair.
    function isGuestOwner(guestId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/guests/$(guestId))
        && get(/databases/$(database)/documents/guests/$(guestId)).data.firebaseUid == request.auth.uid;
    }

    function galleryFields() {
      return request.resource.data.keys().hasOnly([
        'photoUrl', 'thumbnailUrl', 'uploadedBy', 'guestId', 'uploadedByName', 'uploadedAt',
        'likedBy', 'downloads', 'fileSize', 'width', 'height', 'name', 'publicId'
      ]);
    }

    function wishlistReserveFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reserved', 'reservedBy', 'reservedAt'])
        && request.resource.data.reserved == true
        && resource.data.reserved == false;
    }

    match /gallery/{photoId} {
      allow read: if true;
      allow create: if signedAdmin() || (request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid
        && galleryFields()
        && request.resource.data.likedBy.size() == 0
        && request.resource.data.downloads == 0);
      allow update: if signedAdmin()
        || (
          // download counter: monotonic, nothing else changes
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads'])
          && request.resource.data.downloads >= resource.data.downloads
        )
        || (
          // like toggle: exactly the caller's own uid added or removed from
          // likedBy, nothing else in the write. Keyed on request.auth.uid
          // (not the human guestId) so this needs no reverse-lookup and
          // can't be spoofed to like/unlike on someone else's behalf.
          // Order-independent on purpose: arrayRemove() takes the uid out of
          // wherever it sits, not necessarily the end of the list.
          // resource.data.get('likedBy', []) (not resource.data.likedBy):
          // photos uploaded before this array existed have no likedBy field
          // at all — reading a missing field directly errors the whole rule
          // out (not "empty list"), which silently blocked likes on every
          // pre-existing photo even with this rule deployed.
          request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
          && (
            (
              !(request.auth.uid in resource.data.get('likedBy', []))
              && request.auth.uid in request.resource.data.likedBy
              && request.resource.data.likedBy.size() == resource.data.get('likedBy', []).size() + 1
              && request.resource.data.likedBy.hasAll(resource.data.get('likedBy', []))
            )
            || (
              request.auth.uid in resource.data.get('likedBy', [])
              && !(request.auth.uid in request.resource.data.likedBy)
              && resource.data.get('likedBy', []).size() == request.resource.data.likedBy.size() + 1
              && resource.data.get('likedBy', []).hasAll(request.resource.data.likedBy)
            )
          )
        );
      allow delete: if signedAdmin() || (request.auth != null && (
        resource.data.uploadedBy == request.auth.uid
        || (resource.data.guestId is string && resource.data.guestId != '' && isGuestOwner(resource.data.guestId))
      ));
    }

    // Up to 3 votes per guest, split across two venue categories. Doc id is
    // always `{guestId}_slot1|slot2|slot3` — with only 3 valid ids per guest,
    // the 3-vote cap is structural, not something rules have to count.
    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(['guestId', 'placeId', 'venue', 'timestamp'])
        && request.resource.data.keys().hasOnly(['guestId', 'placeId', 'venue', 'timestamp'])
        && request.resource.data.guestId is string
        && request.resource.data.placeId is string
        && request.resource.data.placeId != ''
        && request.resource.data.venue in ['home', 'out']
        && isGuestOwner(request.resource.data.guestId)
        && voteId in [
          request.resource.data.guestId + '_slot1',
          request.resource.data.guestId + '_slot2',
          request.resource.data.guestId + '_slot3'
        ];
      // signedAdmin() so the admin can bulk-clear test votes before launch
      // (Admin → Голоси → "Скинути голосування") — previously only a vote's
      // own guest could remove it, so not even the admin could reset this.
      allow delete: if signedAdmin() || (request.auth != null && isGuestOwner(resource.data.guestId));
    }

    // Public "Хто ти?" identity list — fully self-service. Anyone signed in
    // (anonymously) can create their own guest doc with their own name +
    // nickname; `nickname` on an existing doc is claimed once (never
    // overwritten while already set, unless it's an unchanged rebind to a
    // new device — see js/guest.js) or reset by the admin.
    match /guests/{guestId} {
      allow read: if true;
      allow create: if signedAdmin() || (
        request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'nickname', 'firebaseUid', 'createdAt'])
        && request.resource.data.firebaseUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 24
      );
      allow update: if signedAdmin() || (
        request.auth != null
        && request.resource.data.name == resource.data.name
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'firebaseUid', 'updatedAt'])
        && request.resource.data.firebaseUid == request.auth.uid
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && (
          !('nickname' in resource.data) || resource.data.nickname == ''
          || request.resource.data.nickname == resource.data.nickname
        )
      );
      allow delete: if signedAdmin();
    }

    match /wishlist/{itemId} {
      allow read: if true;
      allow create, delete: if signedAdmin();
      allow update: if signedAdmin() || wishlistReserveFields();
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if signedAdmin();
    }

    match /checklist/{docId} {
      allow read: if true;
      allow create, update, delete: if signedAdmin();
    }

    match /{collectionName}/{documentId} {
      allow read: if collectionName in ['restaurants', 'transport', 'news', 'activity', 'weatherCache'];
      allow create, update, delete: if signedAdmin();
    }
  }
}
