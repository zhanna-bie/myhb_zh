rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedAdmin() { return request.auth != null && request.auth.token.email == 'zhannabie@gmail.com'; }
    function galleryFields() { return request.resource.data.keys().hasOnly(['photoUrl','thumbnailUrl','uploadedBy','uploadedByName','uploadedAt','likes','downloads','fileSize','width','height','name','publicId']); }
    match /gallery/{photoId} {
      allow read: if true;
      allow create: if galleryFields() && request.resource.data.likes == 0 && request.resource.data.downloads == 0;
      allow update: if signedAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','downloads']) && request.resource.data.likes >= resource.data.likes && request.resource.data.downloads >= resource.data.downloads);
      allow delete: if signedAdmin();
    }
    match /votes/{inviteId} { allow read: if true; allow create: if request.resource.data.keys().hasOnly(['invitationId','type','restaurant','timestamp']); allow update, delete: if false; }
    match /{collectionName}/{documentId} { allow read: if collectionName in ['restaurants','transport','news','wishlist','checklist','settings','activity','weatherCache']; allow create, update, delete: if signedAdmin(); }
  }
}
